# ── IAM (nextjs-iam) ────────────────────────────────────────────────────────────
# URL of the IAM service — the OAuth 2.1 authorization server.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3001

# OAuth 2.1 client credentials registered in the IAM.
# Client ID is public (safe for the browser); secret is server-only.
NEXT_PUBLIC_BETTER_AUTH_CLIENT_ID=filenest-console
BETTER_AUTH_CLIENT_SECRET=

# ── This app ────────────────────────────────────────────────────────────────────
# Public URL of the console app — used to build the OAuth redirect_uri.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── FileNest API ────────────────────────────────────────────────────────────────
# Server-side API key for server components and server actions.
# Never expose this to the browser.
FILENEST_API_KEY=fn_live_

# Project ID safe for browser use (no secret — the API key stays server-side).
NEXT_PUBLIC_FILENEST_PROJECT_ID=

# Internal URL of the FileNest FastAPI backend (server-to-server calls only).
FILENEST_API_URL=http://localhost:8001

# ── Webhooks ────────────────────────────────────────────────────────────────────
# Secret used to verify x-filenest-signature on incoming webhook events.
FILENEST_WEBHOOK_SECRET=
