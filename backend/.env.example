# ── Runtime environment ────────────────────────────────────────────────────────
ENV=development
SERVICE_NAME=filenest

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_PRIMARY_URL=postgresql+asyncpg://filenest:filenest@localhost:5434/filenest
DATABASE_REPLICA_URL=postgresql+asyncpg://filenest:filenest@localhost:5434/filenest
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── NATS ───────────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_STREAM_NAME=FILENEST_EVENTS

# ── ClamAV ─────────────────────────────────────────────────────────────────────
# "clamav" resolves inside Docker only — use localhost when running backend locally.
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=300

# ── IAM ────────────────────────────────────────────────────────────────────────
# URL of the BetterAuth IAM service. The backend calls /api/internal/verify-api-key
# to validate fn_live_ / fn_test_ API keys, and /api/auth/jwks for JWT verification.
IAM_URL=http://localhost:3000

# ── Storage ────────────────────────────────────────────────────────────────────
# Active provider for the managed (platform-owned) storage tier.
# Supported: s3 | minio | rustfs | r2 | azure_blob | gcs
DEFAULT_STORAGE_PROVIDER=s3

# ── AWS S3 ─────────────────────────────────────────────────────────────────────
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=filenest
S3_REGION=us-east-1

# ── MinIO ──────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY_ID=
MINIO_SECRET_ACCESS_KEY=
MINIO_BUCKET_NAME=filenest
MINIO_REGION=us-east-1
# SSE-S3 key — configure this on the MinIO server (MINIO_KMS_SECRET_KEY).
# When a project has sse_enabled=true, FileNest sends ServerSideEncryption: AES256.
# Generate: openssl rand -hex 32
MINIO_KMS_SECRET_KEY=

# ── RustFS ─────────────────────────────────────────────────────────────────────
RUSTFS_ENDPOINT_URL=http://localhost:9000
RUSTFS_ACCESS_KEY_ID=
RUSTFS_SECRET_ACCESS_KEY=
RUSTFS_BUCKET_NAME=filenest
RUSTFS_REGION=us-east-1
# SSE-S3 key — configure on the RustFS server process.
# Generate: openssl rand -hex 32
RUSTFS_KMS_SECRET_KEY=

# ── Cloudflare R2 ──────────────────────────────────────────────────────────────
# Endpoint format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=filenest
R2_REGION=auto

# ── Azure Blob Storage (set when DEFAULT_STORAGE_PROVIDER=azure_blob) ──────────
AZURE_ACCOUNT_NAME=
AZURE_ACCOUNT_KEY=

# ── Google Cloud Storage (set when DEFAULT_STORAGE_PROVIDER=gcs) ───────────────
GCS_PROJECT_ID=
# Provide one of the following (credentials_json takes precedence over file, file over ADC):
GCS_CREDENTIALS_JSON=
GCS_CREDENTIALS_FILE=

# ── Encryption ─────────────────────────────────────────────────────────────────
# AES-256-GCM key for BYOB credential encryption (32-byte base64-encoded value).
# Generate with: openssl rand -base64 32
STORAGE_ENCRYPTION_KEY=

# ── Security ───────────────────────────────────────────────────────────────────
# HS256 secret used for local JWT testing only.
# Production JWT verification uses JWKS from the IAM.
JWT_SECRET_KEY=dev-secret-change-in-production

# ── Upload thresholds ──────────────────────────────────────────────────────────
MULTIPART_THRESHOLD_BYTES=104857600

# ── Feature flags ──────────────────────────────────────────────────────────────
HEALTHCARE_PACK_ENABLED=false

# ── Observability ──────────────────────────────────────────────────────────────
OTEL_ENDPOINT=http://localhost:4317
