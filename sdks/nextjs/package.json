{
  "name": "@filenest/nextjs",
  "version": "0.1.0",
  "description": "FileNest SDK for Next.js — server utilities, token creation, and webhook helpers",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {
    "next": ">=14"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "@filenest/core": "workspace:*",
    "@filenest/node": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  }
}
