# ── Runtime environment ────────────────────────────────────────────────────────
ENV=development
SERVICE_NAME=filenest

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_PRIMARY_URL=postgresql+asyncpg://filenest:filenest@localhost:5434/filenest
DATABASE_REPLICA_URL=postgresql+asyncpg://filenest:filenest@localhost:5434/filenest
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CLUSTER_MODE=false

# ── NATS ───────────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_STREAM_NAME=FILENEST_EVENTS

# ── Storage ────────────────────────────────────────────────────────────────────
# Provider type: "s3" works for AWS S3, RustFS, MinIO, Cloudflare R2, and any
# S3-compatible endpoint. Future values: "azure", "gcs".
DEFAULT_STORAGE_PROVIDER=s3

# S3-compatible settings — used for all s3 providers.
# For AWS S3 production:    leave S3_ENDPOINT_URL empty (boto3 default).
# For RustFS / MinIO local: set S3_ENDPOINT_URL=http://localhost:9000
# For Cloudflare R2:        set S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=rustfsadmin
S3_BUCKET_NAME=filenest
S3_REGION=us-east-1
# Force path-style access — required for RustFS, MinIO, and R2.
# Set to false when using AWS S3 with virtual-hosted-style URLs.
S3_FORCE_PATH_STYLE=true

# Encryption key for server-side envelope encryption (32-byte base64-encoded AES-256 key).
# Leave empty to disable server-side encryption (use storage-native SSE instead).
STORAGE_ENCRYPTION_KEY=

# ── Security ───────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-change-in-production
API_KEY_SALT=dev-salt-change-in-production

# ── Upload thresholds ──────────────────────────────────────────────────────────
# Files larger than this use multipart upload protocol (Phase 2).
MULTIPART_THRESHOLD_BYTES=104857600

# ── Feature flags ──────────────────────────────────────────────────────────────
HEALTHCARE_PACK_ENABLED=false

# ── Observability ──────────────────────────────────────────────────────────────
OTEL_ENDPOINT=http://localhost:4317
