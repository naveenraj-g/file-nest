# Get your API key from the FileNest Console → Project → API Keys
FILENEST_API_KEY=fn_live_...

# Get your Project ID from the FileNest Console → Projects
FILENEST_PROJECT_ID=proj_...

# FileNest backend URL (use http://localhost:8000 for local dev)
FILENEST_API_URL=http://localhost:8000

# Webhook signing secret — set this to the value shown in Console → Webhooks
FILENEST_WEBHOOK_SECRET=whsec_...
