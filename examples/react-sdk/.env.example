# Get your Project ID from the FileNest Console → Projects
VITE_FILENEST_PROJECT_ID=proj_...

# FileNest backend URL (use http://localhost:8000 for local dev)
VITE_FILENEST_API_URL=http://localhost:8000

# Token endpoint on YOUR server that issues short-lived upload tokens.
# The example uses a mock; replace with your real endpoint.
VITE_FILENEST_TOKEN_ENDPOINT=http://localhost:3000/api/filenest-token
