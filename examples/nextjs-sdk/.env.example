# FileNest API credentials — copy to .env.local and fill in values
# Get these from the FileNest Console → Projects → API Keys

FILENEST_API_KEY=fn_live_your_api_key_here
FILENEST_PROJECT_ID=proj_your_project_id_here
FILENEST_API_URL=http://localhost:8000

# Webhook signing secret — generated when you create a webhook endpoint in the Console
FILENEST_WEBHOOK_SECRET=your_webhook_secret_here

# Public env vars (safe to expose in the browser)
NEXT_PUBLIC_FILENEST_PROJECT_ID=proj_your_project_id_here
NEXT_PUBLIC_FILENEST_API_URL=http://localhost:8000
